{
  "name": "cashu",
  "version": "0.0.1",
  "description": "Cashu.me Wallet",
  "productName": "Cashu.me",
  "author": "cashu.me",
  "private": true,
  "scripts": {
    "i18n:check": "node scripts/check-i18n.js",
    "dev": "concurrently -k -n embed,quasar -c blue,magenta \"yarn build:embed --watch\" \"quasar dev\"",
    "build": "yarn build:embed && quasar build",
    "build:embed": "vite build --config vite.embed.config.ts",
    "build:pwa": "yarn build:embed && quasar build -m pwa",
    "build:electron": "yarn build:embed && quasar build -m electron",
    "quasar": "quasar",
    "lint": "eslint --ext .js,.vue,.ts ./",
    "format": "prettier --write .",
    "checkformat": "prettier --check .",
    "test": "vitest",
    "test:ci": "vitest run"
  },
  "dependencies": {
